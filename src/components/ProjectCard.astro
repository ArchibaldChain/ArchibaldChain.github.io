---
interface Props {
	image: string;
	date: string;
	title: string;
	description: string;
	href?: string;
	links?: Array<{
		type: "github" | "document" | "external";
		href: string;
		label: string;
	}>;
	readMoreLabel?: string;
}

const { image, date, title, description, href, links = [], readMoreLabel = "Read More" } = Astro.props;

const iconByType = {
	github: "ion-social-github",
	document: "ion-document-text",
	external: "ion-android-open",
};
---

<div class="col-12 col-md-6 col-lg-4 project-card-col">
	<article class="card">
		<img class="card-img-top" src={image} alt="Article Image" />
		<div class="card-body">
			<div class="card-subtitle mb-2 text-muted">{date}</div>
			<h4 class="card-title">
				{href ? <a href={href}>{title}</a> : title}
			</h4>
			<p class="card-text">{description}</p>
			<div class="card-actions">
				{links.map((link) => (
					<a class="card-action-icon" href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label}>
						<i class={iconByType[link.type]}></i>
					</a>
				))}
				{href && (
					<a href={href} class="card-more">
						{readMoreLabel}
						<i class="ion-ios-arrow-right"></i>
					</a>
				)}
			</div>
		</div>
	</article>
</div>
