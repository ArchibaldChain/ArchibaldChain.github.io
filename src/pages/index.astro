---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { homeContent } from "../data/home.en";

const articles = (await getCollection("articles"))
	.map((article) => ({
		slug: article.id.replace(/\.md$/, ""),
		...article.data,
	}))
	.sort((a, b) => String(b.date).localeCompare(String(a.date)))
	.slice(0, 3);

---

<BaseLayout title={homeContent.title} includeTimeline>
	<Navbar items={homeContent.navItems} languageHref={homeContent.languageHref} languageLabel={homeContent.languageLabel} />
	<Hero
		lead={homeContent.hero.lead}
		headingPrefix={homeContent.hero.headingPrefix}
		highlight={homeContent.hero.highlight}
		headingSuffix={homeContent.hero.headingSuffix}
		ctaLabel={homeContent.hero.ctaLabel}
	/>

	<section class="padding container" id="Experience">
		<h2 class="section-title">{homeContent.journeySection.title}</h2>
		<div class="timeline">
			{
				homeContent.journeySection.items.map((item) => (
					<article class="timeline__item">
						<div class="timeline__date">{item.date}</div>
						<div class="timeline__middle"><div class="timeline__point"></div></div>
						<div class="timeline__component timeline__component--bg">
							<h2 class="timeline__title">
								<span class={`timeline__icon${item.icon.type === "image" && item.icon.wide ? " timeline__icon--wide" : ""}`} aria-hidden="true">
									{item.icon.type === "image" ? (
										<img src={item.icon.src} alt={item.icon.alt} width="42" />
									) : (
										<i class={item.icon.name}></i>
									)}
								</span>
								<span>{item.organization}</span>
							</h2>
							<p class="timeline__subtitle">{item.stage}</p>
							{item.description && <p class="timeline__paragraph">{item.description}</p>}
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="padding container" id="articles">
		<h2 class="section-title">{homeContent.articlesSection.title}</h2>
		<p class="section-lead text-muted">{homeContent.articlesSection.lead}</p>
		<div class="section-body">
			<div class="row col-spacing">
				{articles.map((article) => (
					<div class="col-12 col-md-6 col-lg-4">
						<article class="card">
							<div class="card-body">
								<div class="card-subtitle mb-2 text-muted">{article.date}</div>
								<h4 class="card-title"><a href={`/articles/${article.slug}.html`}>{article.title}</a></h4>
								<p class="card-text">{article.description}</p>
								<div class="text-right">
									<a href={`/articles/${article.slug}.html`} class="card-more">
										{homeContent.articlesSection.readMoreLabel}
										<i class="ion-ios-arrow-right"></i>
									</a>
								</div>
							</div>
						</article>
					</div>
				))}
			</div>
			<div class="text-center mt-4">
				<a class="btn btn-primary" href="/articles.html">{homeContent.articlesSection.viewAllLabel}</a>
			</div>
		</div>
	</section>

	<section class="padding bg-grey" id="project">
		<div class="container">
			<h2 class="section-title">{homeContent.projectsSection.title}</h2>
			<p class="section-lead text-muted">{homeContent.projectsSection.lead}</p>
			<div class="section-body">
				<div class="row col-spacing">
					{homeContent.projectsSection.items.map((project) => <ProjectCard {...project} readMoreLabel={homeContent.projectsSection.readMoreLabel} />)}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-overlay padding" id="aboutme" data-bg="/img/projects.jpeg">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-12 col-md-6">
					<figure class="projects-picture"><img src="/img/youzhang.png" alt={homeContent.about.imageAlt} /></figure>
				</div>
				<div class="col-12 col-md-6">
					<div class="projects-details">
						<div class="projects-badge">{homeContent.about.badge}</div>
						<h2 class="projects-title">{homeContent.about.title}</h2>
						{homeContent.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>
				</div>
			</div>
		</div>
	</section>

	<ContactSection
		title={homeContent.contact.title}
		lead={homeContent.contact.lead}
		text={homeContent.contact.text}
		placeholders={homeContent.contact.placeholders}
	/>
	<Footer />
</BaseLayout>
